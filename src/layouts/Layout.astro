---
import "../styles/global.css";
// --- NEW: Import the Astro Router ---
import { ClientRouter } from "astro:transitions";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Footer from "../components/Footer.astro";
import Sidebar from "../components/Sidebar.astro";
import { useTranslations } from "../i18n/utils";

interface Props {
	title: string;
	description?: string;
}

const { title, description } = Astro.props;
const validLanguages = ["en", "ro", "es"] as const;
const lang = (
	validLanguages.includes(Astro.params.lang as never) ? Astro.params.lang : "en"
) as "en" | "ro" | "es";
const t = useTranslations(lang);
const metaDesc = description || t("home.desc").substring(0, 160);
---

<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Security Headers for Static Sites -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://images.unsplash.com blob:; connect-src 'self' https://cdnjs.cloudflare.com; worker-src 'self' blob:; base-uri 'self'; form-action 'self';">
    <title>{title} | Scale Automata</title>
    
    <meta name="description" content={metaDesc}>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Geostar+Fill&family=Inter:wght@300;400;600&family=Russo+One&display=optional">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geostar+Fill&family=Inter:wght@300;400;600&family=Russo+One&display=optional" media="print" onload="this.media='all'">
    <noscript>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geostar+Fill&family=Inter:wght@300;400;600&family=Russo+One&display=optional">
    </noscript>

    <ClientRouter />

    <script is:inline>
        function initTheme() {
            const savedTheme = localStorage.getItem('siteTheme');
            const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
                document.documentElement.setAttribute('data-theme', 'dark');
            } else {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        }
        initTheme(); 
        document.addEventListener('astro:after-swap', initTheme); 
    </script>

    <style is:global>
      html.is-animating .reveal { opacity: 1 !important; transform: none !important; }
      .reveal { opacity: 1 !important; transform: translateY(0) !important; }
      .lang-btn { color: var(--neon-blue) !important; opacity: 0.6 !important; }
      .lang-btn.active { opacity: 1 !important; }
      footer a, .footer-area a { color: var(--neon-blue) !important; }
    </style>
</head>
<body>

<div id="vanta-bg" transition:persist style="position: fixed; z-index: -1; top: 0; left: 0; width: 100vw; height: 100vh;"></div>

<div class="app-container" id="app">
    <Sidebar transition:persist />
    <main class="main-content" id="main-content">
        <Breadcrumbs />
        <slot />
        <Footer transition:persist />
    </main>
</div>

<script is:inline>
    // ==========================================
    // UNIFIED APP LOGIC (Vanta + Scroll Reveal)
    // ==========================================

    const startVanta = () => {
        if (window.vantaEffect) return;
        if (typeof window.VANTA === 'undefined' || typeof window.VANTA.BIRDS === 'undefined') {
            requestAnimationFrame(startVanta);
            return;
        }

        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        const darkBg = 0x000000;
        const lightBg = 0xffffff;

        window.vantaEffect = window.VANTA.BIRDS({
            el: "#vanta-bg",
            mouseControls: true,
            touchControls: true,
            gyroControls: false,
            minHeight: 200.00,
            minWidth: 200.00,
            scale: 2.00,
            scaleMobile: 2.00,
            backgroundColor: isDark ? darkBg : lightBg,
            color1: 0x00f6ff, 
            color2: 0x04fb01,
            colorMode: "variance",
            birdSize: 0.80,
            wingSpan: 29.00,
            speedLimit: 3.00,
            separation: 98.00,
            alignment: 1.00,
            cohesion: 100.00,
            quantity: 3.00
        });

        // Vanta.js native color transition to replace heavy CSS filters
        const colors = [
            { c1: 0x00f6ff, c2: 0x04fb01 }, // Original
            { c1: 0xff00f6, c2: 0x0004fb }, // Approximating -65deg hue rotation
            { c1: 0xf6ff00, c2: 0xfb0104 }  // Approximating 60deg hue rotation
        ];
        let colorIndex = 0;

        const changeColors = () => {
            if (window.vantaEffect) {
                colorIndex = (colorIndex + 1) % colors.length;
                const nextColors = colors[colorIndex];

                // Vanta doesn't have built-in smooth tweening for setOptions,
                // but setting options is much lighter than a full-canvas CSS filter.
                window.vantaEffect.setOptions({
                    color1: nextColors.c1,
                    color2: nextColors.c2
                });
            }
            const randomInterval = Math.floor(Math.random() * (20000 - 15000 + 1)) + 15000;
            clearTimeout(window.vantaColorTimer);
            window.vantaColorTimer = setTimeout(changeColors, randomInterval);
        };

        clearTimeout(window.vantaColorTimer);
        window.vantaColorTimer = setTimeout(changeColors, 15000);

        const themeObserver = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
                if (mutation.attributeName === 'data-theme' && window.vantaEffect) {
                    const darkNow = document.documentElement.getAttribute('data-theme') === 'dark';
                    window.vantaEffect.setOptions({ 
                        backgroundColor: darkNow ? darkBg : lightBg
                    });
                }
            });
        });
        themeObserver.observe(document.documentElement, { attributes: true });
    };

    const initScrollReveal = () => {
        const reveals = document.querySelectorAll('.reveal');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if(entry.isIntersecting) {
                    entry.target.classList.add('active');
                    // ⚡ Bolt Optimization: Stop observing elements once they are revealed.
                    // This prevents the IntersectionObserver from wasting CPU cycles evaluating
                    // intersection state on scroll for elements that have already been animated.
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        reveals.forEach(reveal => observer.observe(reveal));
    };

    const loadScript = (src) => {
        return new Promise((resolve, reject) => {
            const script = document.createElement('script');
            script.src = src;
            script.onload = resolve;
            script.onerror = reject;
            document.body.appendChild(script);
        });
    };

    const initVantaScripts = async () => {
        if (window.vantaScriptsLoaded) return;
        try {
            await loadScript("https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js");
            await loadScript("https://cdnjs.cloudflare.com/ajax/libs/vanta/0.5.24/vanta.birds.min.js");
            window.vantaScriptsLoaded = true;
            startVanta();
        } catch (e) {
            console.error("Failed to load Vanta scripts", e);
        }
    };

    // Master Initialization Function
    const initApp = () => {
        initScrollReveal();
        if (window.vantaScriptsLoaded) {
            if (window.vantaEffect) {
                window.vantaEffect.resize();
            } else {
                startVanta();
            }
        }
    };

    // Delay script loading to allow FCP/LCP to fire immediately
    const delayedInitVanta = () => {
        if ('requestIdleCallback' in window) {
            requestIdleCallback(() => setTimeout(initVantaScripts, 2500));
        } else {
            setTimeout(initVantaScripts, 2500);
        }
    };

    // Use Astro's page-load for initial and subsequent loads to ensure the document is ready
    document.addEventListener('astro:page-load', () => {
        initApp();
        // Fire Vanta initialization heavily delayed to prioritize core metric scores.
        delayedInitVanta();
    });
</script>

</body>
</html>