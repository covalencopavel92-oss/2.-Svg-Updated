---
import { languages, defaultLang } from '../i18n/ui';

const supportedLangs = Object.keys(languages);
---
<!DOCTYPE html>
<html lang={defaultLang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scale Automata | Select Language</title>
    <meta name="description" content="Scale Automata - Select your preferred language to continue.">
    
    {supportedLangs.map((lang) => (
        <link rel="alternate" hreflang={lang} href={`/${lang}/`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`/${defaultLang}/`} />
    
    <meta http-equiv="refresh" content={`0;url=/${defaultLang}/`}>
    
    <script define:vars={{ supportedLangs, defaultLang }}>
        const userLang = navigator.language || defaultLang;
        const langCode = userLang.split('-')[0];

        // Use replace() instead of href so we don't trap users in a back-button loop
        if (supportedLangs.includes(langCode)) {
            window.location.replace(`/${langCode}/`);
        } else {
            window.location.replace(`/${defaultLang}/`);
        }
    </script>
</head>
<body style="background-color: #000; color: #00f6ff; font-family: 'Inter', sans-serif; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0;">
    <div style="text-align: center;">
        <p>Redirecting to your language...</p>
        <noscript>
            <p>Please select your language:</p>
            {Object.entries(languages).map(([code, name]) => (
                <a href={`/${code}/`} style="color: #00f6ff; margin: 0 10px; text-decoration: none; font-weight: 600;">{name}</a>
            ))}
        </noscript>
    </div>
</body>
</html>