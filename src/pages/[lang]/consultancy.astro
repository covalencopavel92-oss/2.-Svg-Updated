---
import Layout from '../../layouts/Layout.astro';
import Quiz from '../../components/Quiz.astro';
import { languages } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);
---
<Layout title={t('nav.consultancy')}>
    <div class="section-header reveal">
        <h2>{t('consult.title')}</h2>
        <p>{t('consult.subtitle')}</p>
    </div>

    <div class="packages-grid reveal">
        <div class="package-card">
            <h3>Basic Audit</h3>
            <p>Comprehensive SEO and website performance analysis.</p>
            <h2 style="color: var(--text-dark); margin: 1rem 0;">$499</h2>
            <ul style="list-style: none; margin-bottom: 2rem; color: var(--text-light);">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </ul>
        </div>
        <div class="package-card" style="background: var(--transparent); color: var(--main-bg);">
            <h3 style="color: var(--neon-blue);">Growth Roadmap</h3>
            <p>Full-scale marketing strategy & digitalization plan.</p>
            <h2 style="color: var(--main-bg); margin: 1rem 0;">$1,499</h2>
            <ul style="list-style: none; margin-bottom: 2rem; color: #ccc;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </ul>
        </div>
        <div class="package-card">
            <h3>Enterprise Consult</h3>
            <p>Ongoing operational digitalization consulting.</p>
            <h2 style="color: var(--text-dark); margin: 1rem 0;">Custom</h2>
            <ul style="list-style: none; margin-bottom: 2rem; color: var(--text-light);">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </ul>
        </div>
    </div>

    <Quiz />
</Layout>
