---
import Layout from '../../../layouts/Layout.astro';
import { languages } from '../../../i18n/ui';
import { useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);
---
<Layout title={t('nav.services')}>
    <section class="page-view" style="display: block; flex-grow: 1;">
        <div class="section-header reveal">
            <h2>{t('services.title')}</h2>
            <p>{t('services.subtitle')}</p>
        </div>

        <div class="services-grid reveal">
            
            <a href={`/${lang}/services/seo-geo/`} class="service-card glass-panel" style="text-decoration: none;">
                <div style="height: 140px; flex-shrink: 0; width: 100%; margin-bottom: 1rem; pointer-events: none;">
                    <model-viewer 
                        src="/1earth.glb"
                        alt="Globe 3D model" 
                        auto-rotate 
                        rotation-per-second="50deg"
                        disable-zoom 
                        disable-pan
                        shadow-intensity="1"
                        bounds="tight"
                        style="width: 100%; height: 100%; background-color: transparent;">
                    </model-viewer>
                </div>
                <h3>SEO & GEO</h3>
                <p></p>
            </a>
            
            <a href={`/${lang}/services/ppc-and-social-ads/`} class="service-card glass-panel" style="text-decoration: none;">
                <div style="height: 140px; flex-shrink: 0; width: 100%; margin-bottom: 1rem; pointer-events: none;">
                    <model-viewer 
                        src="/Social-media.glb" 
                        alt="3D Megaphone Model" 
                        auto-rotate 
                        rotation-per-second="50deg"
                        disable-zoom 
                        disable-pan
                        shadow-intensity="1"
                        bounds="tight"
                        style="width: 100%; height: 100%; background-color: transparent;">
                    </model-viewer>
                </div>
                <h3>PPC & Social Ads</h3>
                <p></p>
            </a>
            
            <a href={`/${lang}/services/web-and-mobile-development/`} class="service-card glass-panel" style="text-decoration: none;">
                <div style="height: 140px; flex-shrink: 0; width: 100%; margin-bottom: 1rem; pointer-events: none;">
                    <model-viewer 
                        src="/computer.glb" 
                        alt="3D globe Model" 
                        auto-rotate 
                        rotation-per-second="50deg"
                        disable-zoom 
                        disable-pan
                        shadow-intensity="1"
                        bounds="tight"
                        style="width: 100%; height: 100%; background-color: transparent;">
                    </model-viewer>
                </div>
                <h3>Web & Mobile Development</h3>
                <p></p>
            </a>
            
            <a href={`/${lang}/services/social-media-marketing/`} class="service-card glass-panel" style="text-decoration: none;">
                <div style="height: 140px; flex-shrink: 0; width: 100%; margin-bottom: 1rem; pointer-events: none;">
                    <model-viewer 
                        src="/1social-media.glb" 
                        alt="3D Like Model" 
                        auto-rotate 
                        rotation-per-second="50deg"
                        disable-zoom 
                        disable-pan
                        shadow-intensity="1"
                        bounds="tight"
                        style="width: 100%; height: 100%; background-color: transparent;">
                    </model-viewer>
                </div>                
                <h3>Social Media Marketing</h3>
                <p></p>
            </a>
            
            <a href={`/${lang}/services/email-marketing/`} class="service-card glass-panel" style="text-decoration: none;">
                 <div style="height: 140px; flex-shrink: 0; width: 100%; margin-bottom: 1rem; pointer-events: none;">
                    <model-viewer 
                        src="/email.glb" 
                        alt="Email 3D model" 
                        auto-rotate 
                        rotation-per-second="50deg"
                        disable-zoom 
                        disable-pan
                        shadow-intensity="1"
                        bounds="tight"
                        style="width: 100%; height: 100%; background-color: transparent;">
                    </model-viewer>
                </div>       
                <h3>Email Marketing</h3>
                <p></p>
            </a>
            
            <a href={`/${lang}/services/data-analytics/`} class="service-card glass-panel" style="text-decoration: none;">
                <div style="height: 140px; flex-shrink: 0; width: 100%; margin-bottom: 1rem; pointer-events: none;">
                    <model-viewer 
                        src="/data-analysis.glb" 
                        alt="Coins 3D Model" 
                        auto-rotate 
                        rotation-per-second="50deg"
                        disable-zoom 
                        disable-pan
                        shadow-intensity="1"
                        bounds="tight"
                        style="width: 100%; height: 100%; background-color: transparent;">
                    </model-viewer>
                </div>
                <h3>Data Analytics</h3>
                <p></p>
            </a>

        </div>
    </section>
</Layout>