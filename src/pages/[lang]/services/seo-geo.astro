---
// Note the extra '../' in the import paths because we are one folder deeper now!
import Layout from '../../../layouts/Layout.astro';
import { languages } from '../../../i18n/ui';
import { useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);
---

<Layout title="Technical & Content SEO & GEO | Scale Automata">
    <section class="page-view page-view-layout">
        
        <div class="hero-section hero-section-wrapper">
            <div class="reveal">
                <h1 class="hero-title title-overflow">
                    <span class="pan-wrapper">
                        Technical & Content<br/>SEO & GEO
                    </span>
                </h1>
                
                <h2 class="hero-subtitle">
                    We execute deep technical audits, build high-authority backlinks, and craft optimized content that ranks.
                </h2>
                
                <div class="hero-description text-left-indented">
                    <p>Right now, potential customers are searching for exactly what you offer. The question is: Are they finding you, or your competitors? We know you need rapid growth and a clear path to increase sales without paying an exorbitant price. Our unified approach to SEO and Geo ensures your brand is visible exactly where it matters most.</p>
                    
                    <p>People don't scroll past the first page; they trust the top results. We get you there. By combining deep technical website audits with high-authority backlinking, we force the search engine to recognize your authority.</p>
                    
                    <p>Whether a user is typing a query into Google Search or asking a generative AI on Bing Search, we ensure your business climbs the ranking. We don't just aim for traffic; we aim for the right page results that bring buyers directly to your site. Practical, transparent, and built for conversion.</p>
                </div>
                
                <div class="action-buttons-wrapper">
                    <a href={`/${lang}/contact/`} class="btn btn-neon dark-bg reveal" style="transition-delay: 0.1s;">
                        Start Growing
                    </a>
                </div>
            </div>
        </div>

    </section>
</Layout>

<style>
    /* Scoped styles specifically for the SEO & GEO glass panel text formatting */
    .text-left-indented {
        text-align: justify;
        padding: 3.5rem 4rem; /* Adds nice breathing room around the paragraphs */
    }

    .text-left-indented p {
        text-indent: 2.5rem; /* Indents the first line of each paragraph */
        margin-bottom: 1.5rem; /* Spaces out the paragraphs */
        line-height: 1.8;
    }

    .text-left-indented p:last-child {
        margin-bottom: 0; /* Prevents extra space at the bottom of the card */
    }
    
    /* Ensures it still looks great on mobile phones */
    @media (max-width: 768px) {
        .text-left-indented {
            padding: 2rem 1.5rem;
        }
        .text-left-indented p {
            text-indent: 1.5rem;
            margin-bottom: 1rem;
        }
    }
</style>