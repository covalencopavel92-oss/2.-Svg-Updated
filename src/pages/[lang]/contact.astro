---
import ContactForm from "../../components/ContactForm.astro";
import { languages } from "../../i18n/ui";
import { useTranslations } from "../../i18n/utils";
import Layout from "../../layouts/Layout.astro";

export const prerender = true;
export function getStaticPaths() {
	return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as "en" | "ro" | "es");
---
<Layout title={t('nav.contact')}>
    <section class="page-view" style="display: block; flex-grow: 1;">
        <div class="section-header reveal">
            <h2>{t('contact.title')}</h2>
            <p>{t('contact.subtitle')}</p>
        </div>

        <ContactForm />

        <div class="contact-details reveal" style="margin-top: 3rem; text-align: center;">
            <h3 style="margin-bottom: 1rem;">Scale Automata S.R.L.</h3>
            <p><strong>{t('contactDetails.address')}:</strong> Iasi, str. Barbu nr. 14</p>
            <p><strong>{t('contactDetails.phone')}:</strong> <a href="tel:0748198534" style="color: var(--neon-blue); text-decoration: none;">0748198534</a></p>
            <p><strong>{t('contactDetails.whatsapp')}:</strong> <a href="https://wa.me/40748198534" target="_blank" rel="noopener noreferrer" style="color: var(--neon-blue); text-decoration: none;">+40748198534</a></p>
            <p><strong>{t('contactDetails.email')}:</strong> <a href="mailto:Scaleautomata@gmail.com" style="color: var(--neon-blue); text-decoration: none;">Scaleautomata@gmail.com</a></p>
        </div>
    </section>
</Layout>
