---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { languages } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as "en" | "ro" | "es");
---
<Layout title={t('nav.contact')}>
    <section class="page-view" style="display: block; flex-grow: 1;">
        <div class="section-header reveal">
            <h2>{t('contact.title')}</h2>
            <p>{t('contact.subtitle')}</p>
        </div>

        <ContactForm />

        <div class="contact-details reveal" style="margin-top: 3rem; text-align: center;">
            <h3 style="margin-bottom: 1rem;">Scale Automata S.R.L.</h3>
            <p><strong>{t('contactDetails.address')}:</strong> {import.meta.env.PUBLIC_ADDRESS || 'Iasi, str. Barbu nr. 14'}</p>
            <p><strong>{t('contactDetails.phone')}:</strong> <a href={`tel:${import.meta.env.PUBLIC_PHONE_NUMBER || '0748198534'}`} style="color: var(--neon-blue); text-decoration: none;">{import.meta.env.PUBLIC_PHONE_NUMBER || '0748198534'}</a></p>
            <p><strong>{t('contactDetails.whatsapp')}:</strong> <a href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER || '40748198534'}`} target="_blank" rel="noopener noreferrer" style="color: var(--neon-blue); text-decoration: none;">+{import.meta.env.PUBLIC_WHATSAPP_NUMBER || '40748198534'}</a></p>
            <p><strong>{t('contactDetails.email')}:</strong> <a href={`mailto:${import.meta.env.PUBLIC_EMAIL || 'Scaleautomata@gmail.com'}`} style="color: var(--neon-blue); text-decoration: none;">{import.meta.env.PUBLIC_EMAIL || 'Scaleautomata@gmail.com'}</a></p>
        </div>
    </section>
</Layout>
