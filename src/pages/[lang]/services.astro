---
import Layout from '../../layouts/Layout.astro';
import { languages } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);
---
<Layout title={t('nav.services')}>
    <section class="page-view" style="display: block; flex-grow: 1;">
        <div class="section-header reveal">
            <h2>{t('services.title')}</h2>
            <p>{t('services.subtitle')}</p>
        </div>

        <div class="services-grid reveal">
            
            <div class="service-card glass-panel">
                <h3>SEO & GEO</h3>
                <p>Dominate search results and local rankings.</p>
            </div>
            
            <div class="service-card glass-panel">
                <h3>PPC & Social Ads</h3>
                <p>Maximize your return on ad spend with data-driven campaigns across Google Ads, Meta, LinkedIn, and TikTok.</p>
            </div>
            
            <div class="service-card glass-panel">
                <h3>Web & Mobile Development</h3>
                <p>High performance, conversion-optimized websites and mobile applications.</p>
            </div>
            
            <div class="service-card glass-panel">
                <h3>Social Media Marketing</h3>
                <p>Build community and engage with your audience across all major social platforms.</p>
            </div>
            
            <div class="service-card glass-panel">
                <h3>Email Marketing</h3>
                <p>Personalized email campaigns that drive engagement and conversions.</p>
            </div>
            
            <div class="service-card glass-panel">
                <h3>Data Analytics</h3>
                <p>Make data-driven decisions with actionable insights from your marketing efforts.</p>
            </div>

        </div>
    </section>
</Layout>