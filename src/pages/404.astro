---
import { defaultLang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";
import Layout from "../layouts/Layout.astro";

// Astro gives us Astro.url to determine the requested path
const pathname = Astro.url.pathname;
const urlLang = pathname.split("/")[1];
const lang = (["en", "ro", "es"].includes(urlLang) ? urlLang : defaultLang) as
	| "en"
	| "ro"
	| "es";
const t = useTranslations(lang);
---

<Layout title="404 | Page Not Found">
    <section class="page-view flex flex-col justify-center items-center h-full text-center reveal">
        <h1 class="hero-title" style="font-size: 8rem; margin-bottom: 1rem;">404</h1>
        <h2 class="hero-subtitle">We couldn't find what you were looking for.</h2>
        <p class="hero-description" style="max-width: 600px; margin: 0 auto 2rem;">
            The page you requested does not exist or has been moved. But don't worry, you can always navigate back to the home page or explore our services.
        </p>
        <div class="action-buttons-wrapper" style="justify-content: center;">
            <a href={`/${lang}/`} class="btn btn-primary">Go to Home</a>
            <a href={`/${lang}/services/`} class="btn btn-neon">Our Services</a>
        </div>
    </section>
</Layout>
