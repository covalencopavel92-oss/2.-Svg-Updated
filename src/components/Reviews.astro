---
import { useTranslations } from '../i18n/utils';

const lang = (Astro.params.lang || 'en') as 'en' | 'ro' | 'es';
const t = useTranslations(lang);
---
<div class="reviews-masonry reveal">
    <div class="review-card">
        <div class="stars">★★★★★</div>
        <p>"Scale Automata transformed our online presence. Our traffic doubled in 3 months!"</p>
        <div style="font-weight: 600;">- Sarah J., TechFlow Inc.</div>
    </div>
    <div class="review-card">
        <div class="stars">★★★★★</div>
        <p>"Professional, data-driven, and results-oriented. The best consultancy we've worked with."</p>
        <div style="font-weight: 600;">- Mark R., Alpha Logistics</div>
    </div>
    <div class="review-card">
        <div class="stars">★★★★☆</div>
        <p>"Great insights on our internal processes. The digitalization roadmap was clear and actionable."</p>
        <div style="font-weight: 600;">- Elena D., GreenLife</div>
    </div>
    <div class="review-card">
        <div class="stars">★★★★★</div>
        <p>"Their SEO audit uncovered issues we didn't even know existed. Highly recommended."</p>
        <div style="font-weight: 600;">- Tom B., E-Shopify</div>
    </div>
    <div class="review-card">
        <div class="stars">★★★★★</div>
        <p>"We saw a 40% increase in conversions after the website redesign."</p>
        <div style="font-weight: 600;">- Jessica L., FitBrand</div>
    </div>
</div>

<div class="interactive-rating reveal" id="interactiveStars">
    <h3>Rate Your Experience</h3>
    <p>How would you rate our digital insights?</p>
    <div class="rating-stars">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #FFD700;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 6.91 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
    </div>
    <div id="ratingMessage" style="display: none; margin-top: 1rem; color: var(--neon-blue); font-weight: 600;"></div>
</div>

<script>
    const stars = document.querySelectorAll('.rating-stars i');
    const msg = document.getElementById('ratingMessage');

    stars.forEach(star => {
        star.addEventListener('click', (e) => {
            const val = parseInt((e.target as HTMLElement).getAttribute('data-val') || '0');
            stars.forEach((s, index) => {
                if(index < val) {
                    (s as HTMLElement).style.color = 'var(--neon-blue)';
                    s.classList.add('active');
                } else {
                    (s as HTMLElement).style.color = '#444';
                    s.classList.remove('active');
                }
            });
            if (msg) {
                msg.style.display = 'block';
                msg.innerText = `Thank you for rating us ${val} star${val > 1 ? 's' : ''}!`;
            }
        });
    });
</script>
