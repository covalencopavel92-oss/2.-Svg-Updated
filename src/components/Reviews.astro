<div class="interactive-rating reveal" id="interactiveStars">
    <h3>Rate Your Experience</h3>
    <p>How would you rate our digital insights?</p>

    <div class="rating-stars" style="display: flex; gap: 8px; justify-content: center; margin-top: 1rem; cursor: pointer;">
        <button data-val="1" class="star-btn" aria-label="Rate 1 star" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#FFD700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="interactive-star"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 6.91 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        </button>
        <button data-val="2" class="star-btn" aria-label="Rate 2 stars" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#FFD700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="interactive-star"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 6.91 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        </button>
        <button data-val="3" class="star-btn" aria-label="Rate 3 stars" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#FFD700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="interactive-star"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 6.91 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        </button>
        <button data-val="4" class="star-btn" aria-label="Rate 4 stars" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#FFD700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="interactive-star"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 6.91 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        </button>
        <button data-val="5" class="star-btn" aria-label="Rate 5 stars" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#FFD700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="interactive-star"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 6.91 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        </button>
    </div>
    <div id="ratingMessage" style="display: none; margin-top: 1rem; color: var(--neon-blue); font-weight: 600;"></div>
</div>


<style>
    .star-btn {
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        transition: transform 0.2s ease;
        -webkit-tap-highlight-color: transparent; /* Disable native tap glow on mobile */
        outline: none;
    }
    .star-btn:hover {
        transform: scale(1.2);
    }
    .interactive-star {
        transition: fill 0.2s ease;
    }
    .star-btn.active .interactive-star,
    .star-btn.hover-active .interactive-star {
        fill: #FFD700;
    }
</style>

<script>
    document.addEventListener('astro:page-load', () => {
        const ratingContainer = document.querySelector('.rating-stars');
        const stars = document.querySelectorAll('.star-btn');
        const msg = document.getElementById('ratingMessage');
        let currentRating = 0;

        if (!ratingContainer) return;

        stars.forEach((star, index) => {
            // Hover effect
            star.addEventListener('mouseenter', () => {
                stars.forEach((s, i) => {
                    if (i <= index) {
                        s.classList.add('hover-active');
                    } else {
                        s.classList.remove('hover-active');
                    }
                });
            });

            // Click effect
            star.addEventListener('click', (e) => {
                const val = parseInt((e.currentTarget as HTMLButtonElement).getAttribute('data-val') || '0');
                currentRating = val;

                stars.forEach((s, i) => {
                    if (i < val) {
                        s.classList.add('active');
                    } else {
                        s.classList.remove('active');
                    }
                });

                if (msg) {
                    msg.style.display = 'block';
                    msg.innerText = `Thank you for rating us ${val} star${val > 1 ? 's' : ''}!`;
                }
            });
        });

        // Reset hover effect when leaving the container
        ratingContainer.addEventListener('mouseleave', () => {
            stars.forEach(s => s.classList.remove('hover-active'));
        });
    });
</script>
