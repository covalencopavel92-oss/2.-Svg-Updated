---
import { ui } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = (Astro.params.lang as 'en' | 'ro' | 'es') || 'en';
const t = useTranslations(lang);

const navLinks = [
    { href: `/${lang}/`, label: t('nav.home'), icon: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline>' },
    { href: `/${lang}/consultancy/`, label: t('nav.consultancy'), icon: '<circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path>' },
    { href: `/${lang}/services/`, label: t('nav.services'), icon: '<rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line>' },
    { href: `/${lang}/reviews/`, label: t('nav.reviews'), icon: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>' },
    { href: `/${lang}/blog/`, label: t('nav.blog'), icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline>' },
    { href: `/${lang}/contact/`, label: t('nav.contact'), icon: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline>' },
];
---

<nav class="sidebar" id="sidebar-nav">
    <div class="sidebar-header-top">
        <LanguageSwitcher />
        <button class="sidebar-lock-btn" id="sidebarLockBtn" aria-label="Lock/Unlock Sidebar" title="Lock sidebar to keep expanded">
            <svg class="lock-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            <svg class="unlock-icon" style="display: none;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 9.2 1"></path>
            </svg>
        </button>
    </div>

    <a class="brand-logo" href={`/${lang}/`} aria-label="Scale Automata Homepage">
        <img 
            src="/SAlogo.svg" 
            alt="Scale Automata Logo" 
            class="logo-svg" 
            width="48" 
            height="48" 
            style="filter: drop-shadow(0 0 10px var(--neon-blue-dim)); flex-shrink: 0;"
            decoding="async"
        />
        <span class="brand-text">Scale<br>Automata</span>
    </a>

    <button class="hamburger" aria-label="Toggle Menu" id="hamburgerBtn">
        <svg class="fas fa-bars" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
    </button>

    <div class="nav-links" id="navLinks">
        {navLinks.map((link) => (
            <a class="nav-link" href={link.href}>
                <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={link.icon}></svg>
                <span class="nav-text">{link.label}</span>
            </a>
        ))}

        <div class="sidebar-bottom">
            <div class="search-wrapper">
                <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" id="searchInput" class="search-input" placeholder="Search..." autocomplete="off" aria-label="Search" />
                <div id="searchResults" class="search-results"></div>
            </div>

            <div class="theme-switch-wrapper">
                 <span class="theme-text" style="font-size: 0.75rem; text-transform: uppercase; font-weight: 600; color: var(--text-light);">{t('nav.theme') || 'Theme'}</span>
                 
                 <label class="theme-switch" for="themeToggle">
                     <input type="checkbox" id="themeToggle" aria-label="Toggle Dark Mode" />
                     <div class="slider round">
                         <svg class="fas fa-sun" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="5"></circle>
                            <line x1="12" y1="1" x2="12" y2="3"></line>
                            <line x1="12" y1="21" x2="12" y2="23"></line>
                            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                            <line x1="1" y1="12" x2="3" y2="12"></line>
                            <line x1="21" y1="12" x2="23" y2="12"></line>
                            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                        </svg>
                         <svg class="fas fa-moon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                        </svg>
                     </div>
                 </label>
             </div>
        </div>
    </div>
</nav>

<script>
    // 1. Global tracker for physical hover state and lock state
    let isSidebarHovered = false;
    const SIDEBAR_EXPANDED_KEY = 'sidebarExpanded';
    const SIDEBAR_LOCKED_KEY = 'sidebarLocked';
    const LANG_EXPANDED_KEY = 'langSwitcherExpanded';

   // 2. Intercept Astro's DOM swap BEFORE it happens
    document.addEventListener('astro:before-swap', (e) => {
        // --- NEW: Preserve Theme Attribute to prevent background flashes ---
        const currentTheme = document.documentElement.getAttribute('data-theme');
        if (currentTheme) {
            e.newDocument.documentElement.setAttribute('data-theme', currentTheme);
        }

        // --- NEW: Preserve Checkbox State to stop slider glitches ---
        const incomingToggle = e.newDocument.getElementById('themeToggle') as HTMLInputElement;
        const currentToggle = document.getElementById('themeToggle') as HTMLInputElement;
        
        if (incomingToggle && currentToggle) {
            incomingToggle.checked = currentToggle.checked;
            if (currentToggle.checked) {
                incomingToggle.setAttribute('checked', 'true');
            }
        }

        // --- EXISTING: Sidebar Lock Logic ---
        // Check if sidebar is locked (always expand) or hover state (expand when hovered)
        const isLocked = localStorage.getItem(SIDEBAR_LOCKED_KEY) === 'true';
        const shouldExpand = isLocked || isSidebarHovered;
        
        if (shouldExpand) {
            // Find the sidebar in the incoming HTML from the next page
            const incomingSidebar = e.newDocument.getElementById('sidebar-nav');
            if (incomingSidebar) {
                // Add the class to the incoming HTML so Astro doesn't strip it during the morph
                incomingSidebar.classList.add('force-expanded');
                // Mark the sidebar as locked so styles apply correctly
                if (isLocked) {
                    incomingSidebar.dataset.sidebarLocked = 'true';
                }
            }
        }
        
        // --- EXISTING: Language Switcher Logic ---
        // Preserve language switcher expanded state during page transitions
        const isLangExpanded = localStorage.getItem(LANG_EXPANDED_KEY) === 'true';
        if (isLangExpanded) {
            const incomingLangSwitcher = e.newDocument.querySelector('.lang-switcher-container') as HTMLElement;
            if (incomingLangSwitcher) {
                incomingLangSwitcher.dataset.langExpanded = 'true';
            }
        }
    });

    // 3. Initialize Sidebar Logic
    function initSidebar() {
        const sidebar = document.getElementById('sidebar-nav');
        if (!sidebar || sidebar.dataset.initialized === 'true') return;
        sidebar.dataset.initialized = 'true';

        // Check if sidebar is locked and restore state
        const isLocked = localStorage.getItem(SIDEBAR_LOCKED_KEY) === 'true';
        if (isLocked) {
            sidebar.classList.add('force-expanded');
            sidebar.dataset.sidebarLocked = 'true';
        } else if (localStorage.getItem(SIDEBAR_EXPANDED_KEY) === 'true') {
            sidebar.classList.add('force-expanded');
        }

        // Update lock button visual state
        const lockBtn = document.getElementById('sidebarLockBtn');
        if (lockBtn) {
            updateLockButtonState(lockBtn, isLocked);
            
            // --- Lock/Unlock Button Logic ---
            lockBtn.addEventListener('click', () => {
                const isCurrentlyLocked = localStorage.getItem(SIDEBAR_LOCKED_KEY) === 'true';
                const newLockedState = !isCurrentlyLocked;
                
                if (newLockedState) {
                    // Lock the sidebar
                    localStorage.setItem(SIDEBAR_LOCKED_KEY, 'true');
                    sidebar.classList.add('force-expanded');
                    sidebar.dataset.sidebarLocked = 'true';
                } else {
                    // Unlock the sidebar
                    localStorage.removeItem(SIDEBAR_LOCKED_KEY);
                    localStorage.removeItem(SIDEBAR_EXPANDED_KEY);
                    sidebar.classList.remove('force-expanded');
                    sidebar.dataset.sidebarLocked = 'false';
                }
                
                updateLockButtonState(lockBtn, newLockedState);
            });
        }

        // --- Language Switcher State Persistence ---
        const langSwitcher = document.querySelector('.lang-switcher-container') as HTMLElement;
        if (langSwitcher) {
            const langCollapsed = langSwitcher.querySelector('.lang-collapsed') as HTMLElement;
            const langExpandedLinks = langSwitcher.querySelector('.lang-expanded') as HTMLElement;
            
            // Click handler to toggle expanded state
            if (langCollapsed) {
                langCollapsed.addEventListener('click', (e) => {
                    e.stopPropagation();
                    // Toggle expanded state
                    const isExpanded = localStorage.getItem(LANG_EXPANDED_KEY) === 'true';
                    if (isExpanded) {
                        localStorage.removeItem(LANG_EXPANDED_KEY);
                        langSwitcher.dataset.langExpanded = 'false';
                    } else {
                        localStorage.setItem(LANG_EXPANDED_KEY, 'true');
                        langSwitcher.dataset.langExpanded = 'true';
                    }
                });
            }
            
            // Set up click handlers for language links to navigate and persist expanded state
            if (langExpandedLinks) {
                const langLinks = langExpandedLinks.querySelectorAll('a.lang-btn');
                langLinks.forEach(link => {
                    link.addEventListener('click', () => {
                        // Keep the expanded state when navigating
                        localStorage.setItem(LANG_EXPANDED_KEY, 'true');
                        langSwitcher.dataset.langExpanded = 'true';
                    });
                });
            }
            
            // Restore expanded state if it was saved
            const isLangExpanded = localStorage.getItem(LANG_EXPANDED_KEY) === 'true';
            if (isLangExpanded) {
                langSwitcher.dataset.langExpanded = 'true';
            } else {
                langSwitcher.dataset.langExpanded = 'false';
            }
        }

        // Track real mouse presence
        sidebar.addEventListener('mouseenter', () => {
            isSidebarHovered = true;
            sidebar.classList.add('force-expanded');
            // Only persist hover if NOT locked
            if (localStorage.getItem(SIDEBAR_LOCKED_KEY) !== 'true') {
                localStorage.setItem(SIDEBAR_EXPANDED_KEY, 'true');
            }
        });
        
        sidebar.addEventListener('mouseleave', () => {
            isSidebarHovered = false;
            // Only collapse if NOT locked
            if (localStorage.getItem(SIDEBAR_LOCKED_KEY) !== 'true') {
                sidebar.classList.remove('force-expanded');
                localStorage.removeItem(SIDEBAR_EXPANDED_KEY);
            }
        });

        // --- Mobile Menu Logic ---
        const btn = document.getElementById('hamburgerBtn');
        const nav = document.getElementById('navLinks');
        
        if (btn && nav) {
            // 1. Toggle menu on button tap
            btn.addEventListener('click', (e) => {
                e.stopPropagation(); // Prevents the click from immediately triggering the document listener below
                nav.classList.toggle('active');
            });

            // 2. Automatically close the menu when a link is tapped
            nav.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => {
                    nav.classList.remove('active');
                });
            });

            // 3. Automatically close the menu if the user taps outside of it
            document.addEventListener('click', (e) => {
                if (nav.classList.contains('active') && !nav.contains(e.target as Node) && !btn.contains(e.target as Node)) {
                    nav.classList.remove('active');
                }
            });
        }

        // --- Search Filtering Logic ---
        const searchInput = document.getElementById('searchInput') as HTMLInputElement;
        const searchResults = document.getElementById('searchResults');
        const currentLang = document.documentElement.lang || 'en';
        const siteIndex = [
            { title: 'Home', url: `/${currentLang}/`, keywords: 'home strategy rank higher customers assessment agency' },
            { title: 'Consultancy', url: `/${currentLang}/consultancy/`, keywords: 'consultancy advice assessment audit strategy roadmap' },
            { title: 'Services', url: `/${currentLang}/services/`, keywords: 'services web development marketing seo geo cro design online growth' },
            { title: 'Reviews', url: `/${currentLang}/reviews/`, keywords: 'reviews testimonials clients feedback success stories' },
            { title: 'Blog', url: `/${currentLang}/blog/`, keywords: 'blog articles news insights tips learning' },
            { title: 'Contact', url: `/${currentLang}/contact/`, keywords: 'contact message email reach us form help' }
        ];

        if (searchInput && searchResults) {
            let debounceTimer: number;

            searchInput.addEventListener('input', (e) => {
                // Clear the existing timer on every keystroke
                clearTimeout(debounceTimer);
                
                // Set a new timer to execute search after 300ms of inactivity
                debounceTimer = setTimeout(() => {
                    const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
                    searchResults.innerHTML = '';

                    if (query.length > 0) {
                        // ⚡ Bolt Optimization: Added debounce to reduce main thread blocking
                        // This prevents filtering logic and DOM updates on every single keystroke
                        const matches = siteIndex.filter(item =>
                            item.title.toLowerCase().includes(query) || item.keywords.includes(query)
                        );

                        if (matches.length > 0) {
                            matches.forEach(match => {
                                const a = document.createElement('a');
                                a.href = match.url;
                                a.className = 'search-result-item';
                                a.textContent = match.title;
                                searchResults.appendChild(a);
                            });
                            searchResults.style.display = 'flex';
                        } else {
                            const div = document.createElement('div');
                            div.className = 'search-result-none';
                            div.textContent = 'No results found';
                            searchResults.appendChild(div);
                            searchResults.style.display = 'flex';
                        }
                    } else {
                        searchResults.style.display = 'none';
                    }
                }, 300) as unknown as number;
            });

            document.addEventListener('click', (e) => {
                if (!searchInput.contains(e.target as Node) && !searchResults.contains(e.target as Node)) {
                    searchResults.style.display = 'none';
                }
            });
        }

        // --- Theme Logic ---
        const toggle = document.getElementById('themeToggle') as HTMLInputElement;
        if (toggle) {
            const savedTheme = localStorage.getItem('siteTheme');
            const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            toggle.checked = savedTheme === 'dark' || (!savedTheme && prefersDark);

            toggle.addEventListener('change', (e) => {
                const newTheme = (e.target as HTMLInputElement).checked ? 'dark' : 'light';
                document.documentElement.setAttribute('data-theme', newTheme);
                localStorage.setItem('siteTheme', newTheme);
            });
        }
    }

    // Update lock button visual state (locked vs unlocked icons)
    function updateLockButtonState(btn: HTMLElement, isLocked: boolean) {
        const lockIcon = btn.querySelector('.lock-icon') as SVGSVGElement;
        const unlockIcon = btn.querySelector('.unlock-icon') as SVGSVGElement;
        
        if (lockIcon && unlockIcon) {
            if (isLocked) {
                lockIcon.style.display = 'none';
                unlockIcon.style.display = 'block';
                btn.classList.add('locked');
                btn.title = 'Unlock sidebar to use hover-based expansion';
            } else {
                lockIcon.style.display = 'block';
                unlockIcon.style.display = 'none';
                btn.classList.remove('locked');
                btn.title = 'Lock sidebar to keep expanded';
            }
        }
    }

    // 4. Run on every page load
    document.addEventListener('astro:page-load', () => {
        initSidebar();

        // Re-evaluate physical hover state after page loads
        const sidebar = document.getElementById('sidebar-nav');
        if (sidebar && sidebar.matches(':hover')) {
            isSidebarHovered = true;
            sidebar.classList.add('force-expanded');
            if (localStorage.getItem(SIDEBAR_LOCKED_KEY) !== 'true') {
                localStorage.setItem(SIDEBAR_EXPANDED_KEY, 'true');
            }
        }

        // Highlight Active Link
        const currentPath = window.location.pathname;
        document.querySelectorAll('.nav-link').forEach(link => {
            link.classList.remove('active');
            const href = link.getAttribute('href');
            if (href === currentPath || href === currentPath + '/' || href + '/' === currentPath) {
                 link.classList.add('active');
            }
        });
    });
</script>