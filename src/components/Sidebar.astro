
---
import { ui } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = (Astro.params.lang as 'en' | 'ro' | 'es') || 'en';
const t = useTranslations(lang);

const navLinks = [
    { href: `/${lang}/`, label: t('nav.home') },
    { href: `/${lang}/consultancy/`, label: t('nav.consultancy') },
    { href: `/${lang}/services/`, label: t('nav.services') },
    { href: `/${lang}/reviews/`, label: t('nav.reviews') },
    { href: `/${lang}/blog/`, label: t('nav.blog') },
    { href: `/${lang}/contact/`, label: t('nav.contact') },
];
---

<nav class="sidebar" id="sidebar-nav">
    <LanguageSwitcher />

    <a class="brand-logo" href={`/${lang}/`} aria-label="Scale Automata Homepage">
    <svg width="48" height="48" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" style="filter: drop-shadow(0 0 10px var(--neon-blue-dim));">
        <path d="m0 0h31.984v32h-31.984z" fill="#080606"/>
        <g>
            <path d="m14.866 4.2722 2.1721-0.019801c1.0717 3.6717 2.0476 7.4502 3.1428 11.107 0.31614 1.0553 0.64974 2.2112 0.90769 3.3072-0.86425-1.0785-2.328-3.4253-3.2022-4.7404-1.326-1.9085-1.1957-1.834-1.9248-4.5402-0.98459 3.1959-1.9752 7.0839-2.9449 10.417-0.37836 1.2892-0.76332 2.5723-1.1547 3.8493-0.09591 0.31648-0.53507 1.7229-0.56358 1.9626-0.11196 0.94004 0.14355 5.6084-0.0947 6.2802-0.49234 0.16914-2.8929 0.10438-3.5316 0.10472l-7.7093-6.94e-4 5.5041e-4 -7.9329 2.2706 9.58e-4 0.00884 4.0589c2.2198 0.0099 4.5844-0.08655 6.7892 0.04263-0.044248-2.6441-0.030871-5.391-0.035514-8.0455l-9.034-0.0198c-0.0014854-5.2242-0.034587-10.571 0.0072297-15.785l11.395-0.034039 0.0072 7.9144-2.2487-0.0066-0.00879-3.9885-6.8814 1.66e-4 0.00442 8.0032 5.4275-0.0066c0.65955-0.0012 2.8267-0.08259 3.3016 0.15526 0.14931 0.1675 0.18163 0.46241 0.23831 0.76205 0.36132-0.9563 0.84218-2.8728 1.1527-3.967z" fill="#1eeaff"/>
