            <path d="m28.108 5.7885c-0.03653 0.22564-4.5858 9.327-5.0352 10.27l-0.4299-0.9817c-0.23918-0.54599-0.39878-0.91342-0.60144-1.504 0.04825-0.4896 0.06518-0.88395 0.08669-1.3754 0.75107-1.1677 1.6511-2.8291 2.3771-4.0916 1.0166 0.72541 1.2692-0.16618 1.5541-1.3634 0.10141-0.42574 1.6967-0.84048 2.0486-0.95409z" fill="#070707"/>
            <path d="m24.857 5.6215c0.28222-0.17576 0.59193 0.08226 0.69515 0.57889 0.10316 0.49657-0.03844 1.0477-0.31788 1.2368-0.1842 0.12454-0.39203 0.064419-0.54403-0.15758-0.15206-0.22233-0.22473-0.57182-0.19014-0.91507 0.03458-0.34325 0.17088-0.62723 0.3569-0.74302z" fill="#050505"/>
