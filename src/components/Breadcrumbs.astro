---
import type { UIKeys } from "../i18n/ui";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const currentPath = Astro.url.pathname;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Check if we are on the homepage (e.g. "/", "/en", "/en/")
// Since valid languages are 'en', 'ro', 'es' and Astro handles routing,
// the path for the home page will typically be `/${lang}` or `/${lang}/`
const isHomePage =
	currentPath === `/${lang}` ||
	currentPath === `/${lang}/` ||
	currentPath === "/";

// Breadcrumb items logic
let breadcrumbItems: { label: string; url: string }[] = [];

if (!isHomePage) {
	// Split the path and filter out empty segments
	const pathSegments = currentPath
		.split("/")
		.filter((segment) => segment.length > 0);

	// Create the Home breadcrumb item
	breadcrumbItems.push({
		label: t("nav.home"),
		url: `/${lang}/`, // Ensure the user stays in their language when clicking Home
	});

	// Build the rest of the breadcrumbs
	let currentAccumulatedPath = `/${lang}`;

	// We skip the first segment since it is just the language code (e.g., 'en')
	// We only start from index 1 (which would be 'services', 'blog', etc.)
	for (let i = 1; i < pathSegments.length; i++) {
		const segment = pathSegments[i];
		currentAccumulatedPath += `/${segment}`;

		// Attempt to translate the path segment
		const translationKey = `nav.${segment}` as UIKeys;
		const translatedLabel = t(translationKey);

		// If a translation doesn't exist (returns undefined or the key itself), fallback to capitalizing the segment
		const finalLabel =
			translatedLabel && translatedLabel !== translationKey
				? translatedLabel
				: segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, " ");

		breadcrumbItems.push({
			label: finalLabel,
			url: currentAccumulatedPath,
		});
	}

	// Truncate logic
	const MAX_ITEMS = 4;
	if (breadcrumbItems.length > MAX_ITEMS) {
		// If we have more than 4 items, we need to truncate
		// E.g., [Home, Services, Category, Subcategory, Item] (5 items)
		// Becomes: [Home, ..., Subcategory, Item]

		const numToRemove = breadcrumbItems.length - MAX_ITEMS + 1; // +1 to make room for the '...'
		const truncatedItems = [];

		// Always keep Home
		truncatedItems.push(breadcrumbItems[0]);

		// Add '...'
		truncatedItems.push({ label: "...", url: "" });

		// Add the remaining items from the end
		// E.g. if length is 5, MAX_ITEMS is 4, we want to keep index 0, '...', index 3, index 4
		for (
			let i = breadcrumbItems.length - (MAX_ITEMS - 2);
			i < breadcrumbItems.length;
			i++
		) {
			truncatedItems.push(breadcrumbItems[i]);
		}

		breadcrumbItems = truncatedItems;
	}
}
---

{
  !isHomePage && breadcrumbItems.length > 0 && (
    <nav aria-label="Breadcrumb" class="breadcrumbs-container">
      <ol class="breadcrumbs-list">
        {breadcrumbItems.map((item, index) => (
          <li class="breadcrumb-item">
            {item.url ? (
               index === breadcrumbItems.length - 1 ? (
                 <a href={item.url} aria-current="page" class="breadcrumb-link current">{item.label}</a>
               ) : (
                 <a href={item.url} class="breadcrumb-link">{item.label}</a>
               )
            ) : (
              <span class="breadcrumb-ellipsis" aria-hidden="true">{item.label}</span>
            )}

            {/* Render separator > if it's not the last item */}
            {index < breadcrumbItems.length - 1 && (
              <span class="breadcrumb-separator" aria-hidden="true">&gt;</span>
            )}
          </li>
        ))}
      </ol>
    </nav>
  )
}

<style>
  .breadcrumbs-container {
    padding: 0;
    margin-bottom: 1.5rem;
  }

  .breadcrumbs-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .breadcrumb-item {
    display: flex;
    align-items: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
  }

  .breadcrumb-link {
    color: var(--text-color, #a0a0a0);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .breadcrumb-link:hover, .breadcrumb-link:focus-visible {
    color: var(--neon-blue, #00f6ff);
    text-decoration: underline;
  }

  .breadcrumb-link.current {
    color: var(--text-color, #333333);
    font-weight: 600;
    pointer-events: none;
  }

  /* Handle dark mode if it exists */
  :global([data-theme="dark"]) .breadcrumb-link.current {
    color: var(--text-color, #ffffff);
  }

  .breadcrumb-separator {
    margin-left: 0.5rem;
    color: var(--text-color, #666);
    font-size: 0.8rem;
  }

  .breadcrumb-ellipsis {
    color: var(--text-color, #666);
    cursor: default;
  }
</style>