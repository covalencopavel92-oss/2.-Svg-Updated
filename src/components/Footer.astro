---
import { useTranslations } from '../i18n/utils';

const lang = (Astro.params.lang || 'en') as 'en' | 'ro' | 'es';
const t = useTranslations(lang);
---

<footer class="site-footer" id="site-footer">
    <p>&copy; 2026 Scale Automata. All rights reserved.</p>
    <div class="footer-links">
        <a href={`${import.meta.env.BASE_URL}/${lang}/privacy/`}>{t('footer.privacy')}</a>
        <span>|</span>
        <a href={`${import.meta.env.BASE_URL}/${lang}/terms/`}>{t('footer.terms')}</a>
    </div>
</footer>
